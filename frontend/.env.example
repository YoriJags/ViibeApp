# Vibe App Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (without trailing slash)
EXPO_PUBLIC_BACKEND_URL=http://localhost:8001

# Paystack Public Key (for WebView checkout)
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: App Configuration
EXPO_PUBLIC_DEFAULT_CITY=lagos
