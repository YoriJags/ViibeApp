[run]
source = app
omit =
    app/routes/seed.py
    app/services/email.py
    app/services/sms.py
    app/services/expo_push.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
show_missing = true
precision = 1

[html]
directory = htmlcov
